generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int        @id @default(autoincrement())
  name         String?
  email        String     @unique
  passwordHash String
  role         String     @default("operator")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  notes        Note[]
  warnings     Warning[]
}

model Debtor {
  id           Int        @id @default(autoincrement())
  tartibRaqam  Int?
  fish         String
  manzil       String?
  pasport      String?   @unique
  tugilganSana DateTime?
  jshshir      String?   @unique
  telefon      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  photo        String?
  loans        Loan[]
  notes        Note[]
  smsLogs      SmsLog[]
}

model Loan {
  id           Int        @id @default(autoincrement())
  debtorId     Int
  loanType         String
  qarzSummasi      Float
  qarzMatnda       String?
  shartnomaSana    DateTime?
  notarius         String?
  reestrRaqam      String?
  holatSanasi      DateTime?
  muddatOtganSumma Float          @default(0)
  oylikTolov       Float?
  foizStavka       Float?         @default(0)
  status           String         @default("faol")
  riskScore        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  documents        Document[]
  debtor           Debtor         @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  schedules        LoanSchedule[]
  payments         Payment[]
  warnings         Warning[]
}

model LoanSchedule {
  id           Int        @id @default(autoincrement())
  loanId       Int
  oyRaqam   Int
  tolovSana DateTime
  asosiy    Float
  foiz      Float    @default(0)
  jami      Float
  qoldiq    Float
  tolandi   Boolean  @default(false)
  paymentId    Int?
  payment   Payment? @relation(fields: [paymentId], references: [id])
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model PaymentBatch {
  id           Int        @id @default(autoincrement())
  faylNomi      String
  yuklanganSana DateTime  @default(now())
  jami          Int       @default(0)
  moslashdi     Int       @default(0)
  moslashmadi   Int       @default(0)
  jamiSumma     Float     @default(0)
  kimYukladi    String?
  payments      Payment[]
}

model Payment {
  id           Int        @id @default(autoincrement())
  loanId       Int
  summa      Float
  tolovSana  DateTime
  usul       String
  maqsad     String?
  kimKiritdi String?
  batchId      Int?
  createdAt  DateTime       @default(now())
  schedules  LoanSchedule[]
  batch      PaymentBatch?  @relation(fields: [batchId], references: [id])
  loan       Loan           @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model Template {
  id           Int        @id @default(autoincrement())
  nomi          String
  turi          String
  kontent       String
  ozgaruvchilar String
  kimYaratdi    String?
  updatedAt     DateTime   @updatedAt
  documents     Document[]
}

model Document {
  id           Int        @id @default(autoincrement())
  loanId       Int
  hujjatTuri    String
  shablonId    Int?
  faylYoli      String?
  generatedData String?
  holat         String    @default("yaratilgan")
  kimYaratdi    String?
  createdAt     DateTime  @default(now())
  shablon       Template? @relation(fields: [shablonId], references: [id])
  loan          Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  warnings      Warning[]
}

model Note {
  id           Int        @id @default(autoincrement())
  debtorId     Int
  userId       Int?
  matn        String
  eslatmaSana DateTime?
  isEslatma   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])
  debtor      Debtor    @relation(fields: [debtorId], references: [id], onDelete: Cascade)
}

model Warning {
  id           Int        @id @default(autoincrement())
  loanId       Int
  userId       Int?
  documentId   Int?
  turi       String
  sana       DateTime  @default(now())
  raqami     String?
  izoh       String?
  createdAt  DateTime  @default(now())
  document   Document? @relation(fields: [documentId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])
  loan       Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model SmsLog {
  id           Int        @id @default(autoincrement())
  debtorId     Int
  telefon        String
  matn           String
  sabab          String
  holat          String
  yuborilganSana DateTime @default(now())
  createdAt      DateTime @default(now())
  debtor         Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           Int        @id @default(autoincrement())
  userId       Int?
  amal        String
  model       String
  modelId     String?
  eskiQiymat  String?
  yangiQiymat String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model PenaltySetting {
  id           Int        @id @default(autoincrement())
  loanType     String   @unique
  stavkaYillik Float
  faol         Boolean  @default(true)
  updatedBy    String?
  updatedAt    DateTime @updatedAt
}
